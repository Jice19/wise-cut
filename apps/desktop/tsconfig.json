{
    "compilerOptions": {
        "target": "ESNext",
        "module": "esnext",
        "allowJs": true,
        "skipLibCheck": true,
        "esModuleInterop": true,
        "noImplicitAny": true,
        "sourceMap": true,
        "outDir": "dist",
        "moduleResolution": "bundler",
        "resolveJsonModule": true,
        "jsx": "react-jsx",
        "baseUrl": ".",
        "paths": {
            "@/renderer/*": ["./renderer/*"]
        },
        "types": ["./miaoma.env.d.ts"]
    },
    "include": [
        "renderer/**/*",
        "client/**/*",
        "shared/**/*",
        "tests/**/*",
        "miaoma.env.d.ts",
        "forge.env.d.ts"
    ]
}
