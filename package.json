{
    "name": "miaoma-magicut",
    "private": true,
    "version": "1.0.0",
    "description": "AI智能剪辑平台",
    "engines": {
        "node": ">=22 <23"
    },
    "volta": {
        "node": "22.11.0"
    },
    "packageManager": "pnpm@10.29.2",
    "scripts": {
        "start": "pnpm --filter @miaoma-magicut/desktop start",
        "dev:desktop": "pnpm --filter @miaoma-magicut/desktop start",
        "package": "pnpm --filter @miaoma-magicut/desktop package",
        "package:mac": "pnpm --filter @miaoma-magicut/desktop package:mac",
        "package:win": "pnpm --filter @miaoma-magicut/desktop package:win",
        "make": "pnpm --filter @miaoma-magicut/desktop make",
        "make:mac": "pnpm --filter @miaoma-magicut/desktop make:mac",
        "make:win": "pnpm --filter @miaoma-magicut/desktop make:win",
        "publish": "pnpm --filter @miaoma-magicut/desktop publish",
        "dev:server": "pnpm --filter @miaoma-magicut/server dev",
        "build:server": "pnpm --filter @miaoma-magicut/server build",
        "start:server": "pnpm --filter @miaoma-magicut/server start",
        "lint": "pnpm -r --if-present run lint",
        "format": "pnpm -r --if-present run format",
        "spellcheck": "cspell lint --dot --gitignore --color --cache --show-suggestions \"(packages|apps)/**/*.@(html|js|cjs|mjs|ts|tsx|css|scss|md)\"",
        "test": "pnpm -r --if-present run test",
        "test:run": "pnpm -r --if-present run test:run",
        "test:coverage": "pnpm -r --if-present run test:coverage",
        "prepare": "husky",
        "commit": "git-cz"
    },
    "config": {
        "commitizen": {
            "path": "./node_modules/cz-git"
        }
    },
    "lint-staged": {
        "*.{ts,tsx,js,cjs,mjs}": [
            "eslint --fix",
            "prettier --write"
        ],
        "*.{json,md,css,scss,html}": [
            "prettier --write"
        ]
    },
    "devDependencies": {
        "@commitlint/cli": "20.1.0",
        "@commitlint/config-conventional": "20.0.0",
        "@eslint/js": "9.38.0",
        "commitizen": "4.3.1",
        "commitlint": "20.1.0",
        "cz-git": "1.12.0",
        "eslint": "9.38.0",
        "eslint-plugin-prettier": "5.5.4",
        "eslint-plugin-simple-import-sort": "12.1.1",
        "globals": "16.4.0",
        "husky": "9.1.7",
        "lint-staged": "15.5.2",
        "prettier": "3.6.2",
        "typescript": "5.9.3",
        "typescript-eslint": "8.46.2",
        "cspell": "10.0.1"
    }
}
